{
  "name": "ptctl",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "CLI for the Pterodactyl client API.",
  "keywords": [
    "pterodactyl",
    "cli"
  ],
  "homepage": "https://github.com/stdpi/ptctl#readme",
  "bugs": {
    "url": "https://github.com/stdpi/ptctl/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stdpi/ptctl.git"
  },
  "license": "MIT",
  "author": "stdpi",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "pt": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "pt": "bun ./dist/cli.js",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "prepare": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@types/node": "^22.15.30",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
